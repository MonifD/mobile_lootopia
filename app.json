{
  "expo": {
    "name": "Jeu_mobile",
    "slug": "Jeu_mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mobilelootopia",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Lootopia utilise votre position pour vous guider vers les étapes de la chasse au trésor.",
        "NSLocationAlwaysUsageDescription": "Lootopia utilise votre position pour détecter votre proximité avec les étapes."
      },
      "bundleIdentifier": "com.anonymous.mobile-lootopia"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.CAMERA"
      ],
      "package": "com.lootopia.app.master"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo_loot.png",
          "imageWidth": 400,
          "resizeMode": "contain",
          "backgroundColor": "#000000",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Lootopia utilise votre position pour vous guider vers les étapes de la chasse au trésor."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Lootopia utilise la caméra pour scanner les marqueurs AR des étapes de la chasse."
        }
      ],
      "expo-video",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
